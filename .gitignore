# ---------------------------------------------------------------------------
# Python / FastAPI (backend)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
# Anchored to the repo root: these are distutils/setuptools build-output
# directory names that only ever appear where a setup.py/pyproject.toml
# lives. Unanchored, they previously matched any nested directory with the
# same name (e.g. "lib/" silently swallowed the whole frontend/lib/ source
# directory, so it never got committed).
/build/
/develop-eggs/
/dist/
/downloads/
/eggs/
/.eggs/
/lib/
/lib64/
/parts/
/sdist/
/var/
/wheels/
*.egg-info/
.installed.cfg
*.egg

