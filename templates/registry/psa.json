      "required": true
    },
    {
      "id": "customerObligations",
      "label": "Customer Obligations",
      "type": "text",
      "required": true
    },
    {
      "id": "customerPolicies",
      "label": "Customer Policies",
      "type": "text",
      "required": true
    },
    {
      "id": "deliverables",
      "label": "Deliverables",
      "type": "text",
      "required": true
    },
    {
      "id": "effectiveDate",
